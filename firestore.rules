rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Validation helper for email
    function isValidEmail(email) {
      return email is string && email.matches('^.+@.+\\..+$');
    }

    // News collection: Public read, admin write
    match /news/{articleId} {
      allow read: if true;
      allow create, update, delete: if isAuthenticated() 
        && request.resource.data.title is string
        && request.resource.data.category in ['Press Release', 'Impact', 'Technology', 'Community', 'Education', 'Strategic Report', 'In the Field'];
    }
    
    // Applications collection: Public create, admin read/write
    match /applications/{applicationId} {
      allow create: if isValidEmail(request.resource.data.email)
        && request.resource.data.fullName is string
        && request.resource.data.program is string;
      allow read, update, delete: if isAuthenticated();
    }

    // Inquiries collection: Public create, admin read/write
    match /inquiries/{inquiryId} {
      allow create: if isValidEmail(request.resource.data.email)
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.message.size() > 10;
      allow read, update, delete: if isAuthenticated();
    }

    // Newsletter Subscribers: Public create, admin read/write
    match /newsletter_subscribers/{subscriberId} {
      allow create: if isValidEmail(request.resource.data.email);
      allow read, update, delete: if isAuthenticated();
    }

    // Media Requests: Public create, admin read/write
    match /media_requests/{requestId} {
      allow create: if request.resource.data.fullName is string
        && request.resource.data.organization is string
        && request.resource.data.objective is string;
      allow read, update, delete: if isAuthenticated();
    }
    
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
